{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "flutter build apk",
      "type": "shell",
      "command": "flutter build apk --dart-define-from-file=.env",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$flutter-error"
      ]
    },
    {
      "label": "flutter build appbundle",
      "type": "shell",
      "command": "flutter build appbundle --dart-define-from-file=.env",
      "group": "build",
      "problemMatcher": [
        "$flutter-error"
      ]
    }
  ]
}
